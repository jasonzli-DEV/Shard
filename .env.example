# Shard — environment variables
# Copy to .env and fill in values

# Backend server port
PORT=4000

# MongoDB starter cluster URI (stores all metadata)
STARTER_MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/shard?retryWrites=true&w=majority

# JWT signing secret (generate with: openssl rand -hex 64)
JWT_SECRET=change_me_generate_a_secure_random_string

# Frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# Comma-separated allowed origins (production)
ALLOWED_ORIGINS=http://localhost:5173,https://shard.example.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Public URL (used in OAuth callbacks and public links)
PUBLIC_URL=http://localhost:4000

# Log level (error, warn, info, http, debug)
LOG_LEVEL=info

# Cookie security — set to true only when serving over HTTPS/TLS.
# Leave false (default) for plain HTTP deploys such as LAN/Pi without TLS.
# When you add a TLS terminator in front of nginx, set COOKIE_SECURE=true.
COOKIE_SECURE=false

# Path where the setup wizard writes the .env file (inside the container).
# Mount this path as a Docker volume so the file persists across restarts.
# Default: /app/config/.env  (the container must be able to write here)
# SETUP_ENV_FILE_PATH=/app/config/.env

# Default Atlas region for new M0 clusters (optional, defaults to US_EAST_1)
# Valid values: US_EAST_1, US_WEST_2, EU_WEST_1, EU_CENTRAL_1, AP_SOUTHEAST_1, AP_SOUTH_1, SA_EAST_1
# Can be overridden per-OrgKey via the region field in OrgKey settings.
ATLAS_DEFAULT_REGION=US_EAST_1
