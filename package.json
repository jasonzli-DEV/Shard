{
  "name": "shard",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted MongoDB-backed cloud storage",
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "build": "npm run build --workspace=backend && npm run build --workspace=frontend",
    "test": "npm run test --workspace=backend",
    "test:e2e": "playwright test",
    "test:all": "npm run test --workspace=backend && npm run test --workspace=frontend"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
